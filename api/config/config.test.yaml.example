# 复制为 config.test.yaml（APP_ENV=test）；该文件已被 .gitignore，不会提交
app:
  name: "InkMind-测试"
  debug: true
  env: "test"
  logLevel: "debug"
  showStacktrace: false

server:
  port: "10001"
  timeout: 30s
  routerPrefix: ""

database:
  driver: "mysql"
  host: "127.0.0.1"
  port: "3306"
  username: "root"
  password: "your_password"
  database: "inkmind_test"
  options: "charset=utf8mb4&parseTime=True&loc=Local"
  maxOpenConns: 10
  maxIdleConns: 2
  connMaxLifetime: 5m
  logQueries: false
  slowQueryTime: 500

jwt:
  secret: "${JWT_SECRET_TEST}"
  accessExpiry: "1h"
  issuer: "inkmind-test"

upload:
  dir: "uploads"
  urlPrefix: ""

oss:
  endpoint: ""
  accessKeyId: ""
  accessKeySecret: ""
  bucketName: ""
  urlPrefix: ""

ai:
  enabled: false
  baseURL: ""
  apiKey: ""
  model: "qwen-plus"
  referer: ""
  title: ""
