# 复制为 config.dev.yaml 后按需修改（config.dev.yaml 已被 .gitignore，不会提交）
app:
  name: "InkMind-开发版"
  debug: true
  env: "dev"
  logLevel: "debug"
  showStacktrace: true

server:
  port: "10001"
  timeout: 30s
  # 与前端 VITE_ROUTER_PREFIX 一致；空则 API 为 /api
  routerPrefix: ""

database:
  driver: "mysql"
  host: "127.0.0.1"
  port: "3306"
  username: "root"
  password: "your_password"
  # 或使用环境变量：password: "${DB_PASSWORD}"
  database: "inkmind"
  options: "charset=utf8mb4&parseTime=True&loc=Local"
  maxOpenConns: 25
  maxIdleConns: 5
  connMaxLifetime: 5m
  logQueries: true
  slowQueryTime: 200

jwt:
  secret: "${JWT_SECRET}"
  accessExpiry: "24h"
  issuer: "inkmind"

upload:
  dir: "uploads"
  urlPrefix: ""

oss:
  endpoint: ""
  accessKeyId: ""
  accessKeySecret: ""
  bucketName: ""
  urlPrefix: ""

ai:
  enabled: false
  baseURL: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  apiKey: "${DASHSCOPE_API_KEY}"
  model: "qwen-plus"
  referer: ""
  title: ""
