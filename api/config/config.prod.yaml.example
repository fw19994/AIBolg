# 复制为 config.prod.yaml（APP_ENV=prod）；该文件已被 .gitignore，不会提交
app:
  name: "InkMind"
  debug: false
  env: "prod"
  logLevel: "info"
  showStacktrace: false

server:
  port: "10001"
  timeout: 30s
  routerPrefix: ""

database:
  driver: "mysql"
  host: "127.0.0.1"
  port: "3306"
  username: "inkmind_prod"
  password: "${DB_PASSWORD}"
  database: "inkmind"
  options: "charset=utf8mb4&parseTime=True&loc=Local"
  maxOpenConns: 150
  maxIdleConns: 15
  connMaxLifetime: 5m
  logQueries: false
  slowQueryTime: 500

jwt:
  secret: "${JWT_SECRET}"
  accessExpiry: "12h"
  issuer: "inkmind"

upload:
  dir: "uploads"
  urlPrefix: ""

oss:
  endpoint: ""
  accessKeyId: "${OSS_ACCESS_KEY_ID}"
  accessKeySecret: "${OSS_ACCESS_KEY_SECRET}"
  bucketName: ""
  urlPrefix: ""

ai:
  enabled: true
  baseURL: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  apiKey: "${DASHSCOPE_API_KEY}"
  model: "qwen-plus"
  referer: ""
  title: ""
