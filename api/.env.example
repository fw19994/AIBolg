# 环境：development | test | production
APP_ENV=development

# 服务
PORT=10001

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=inkmind

# 阿里云 DashScope 通义千问（与 config 中 ai.apiKey: "${DASHSCOPE_API_KEY}" 对应）
# https://help.aliyun.com/zh/model-studio/get-api-key
DASHSCOPE_API_KEY=
